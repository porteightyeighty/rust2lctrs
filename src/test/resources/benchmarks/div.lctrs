div :: Int -> Int -> result
ret :: Int -> result
err :: result
u1 :: Int -> Int -> Int -> result
u2 :: Int -> Int -> Int -> result

div(a, b) -> err | ¬((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1)))
div(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ ((a ≥ 0) ∨ ((a % b) = 0))) ∧ ($div = (a / b))
div(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b > 0))) ∧ ($div = ((a / b) + 1))
div(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b < 0))) ∧ ($div = ((a / b) - 1))
u1(a, b, $div) -> u2(a, b, $div)
u2(a, b, x) -> ret(x)
