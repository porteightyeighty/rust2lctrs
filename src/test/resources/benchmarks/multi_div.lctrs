multi_div :: Int -> Int -> result
ret :: Int -> result
err :: result
u1 :: Int -> Int -> Int -> result
u2 :: Int -> Int -> Int -> Int -> result
u3 :: Int -> Int -> Int -> Int -> Int -> result
u4 :: Int -> Int -> Int -> Int -> result

multi_div(a, b) -> u1(a, b, 10)
u1(a, b, c) -> err | ¬((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1)))
u1(a, b, c) -> u2(a, b, c, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ ((a ≥ 0) ∨ ((a % b) = 0))) ∧ ($div = (a / b))
u1(a, b, c) -> u2(a, b, c, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b > 0))) ∧ ($div = ((a / b) + 1))
u1(a, b, c) -> u2(a, b, c, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b < 0))) ∧ ($div = ((a / b) - 1))
u2(a, b, c, $div) -> err | ¬((c ≠ 0) ∧ ¬(($div = -32768) ∧ (c = -1)))
u2(a, b, c, $div) -> u3(a, b, c, $div, $div_1) | (((c ≠ 0) ∧ ¬(($div = -32768) ∧ (c = -1))) ∧ (($div ≥ 0) ∨ (($div % c) = 0))) ∧ ($div_1 = ($div / c))
u2(a, b, c, $div) -> u3(a, b, c, $div, $div_1) | (((c ≠ 0) ∧ ¬(($div = -32768) ∧ (c = -1))) ∧ ((($div < 0) ∧ (($div % c) ≠ 0)) ∧ (c > 0))) ∧ ($div_1 = (($div / c) + 1))
u2(a, b, c, $div) -> u3(a, b, c, $div, $div_1) | (((c ≠ 0) ∧ ¬(($div = -32768) ∧ (c = -1))) ∧ ((($div < 0) ∧ (($div % c) ≠ 0)) ∧ (c < 0))) ∧ ($div_1 = (($div / c) - 1))
u3(a, b, c, $div, $div_1) -> err | ¬((-32768 ≤ (1 + $div_1)) ∧ ((1 + $div_1) ≤ 32767))
u3(a, b, c, $div, $div_1) -> u4(a, b, c, 1 + $div_1) | (-32768 ≤ (1 + $div_1)) ∧ ((1 + $div_1) ≤ 32767)
u4(a, b, c, x) -> ret(x)
