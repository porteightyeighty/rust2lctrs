multi_div :: Int -> Int -> result
ret :: Int -> result
err :: result
u1 :: Int -> Int -> Int -> result
u2 :: Int -> Int -> Int -> Int -> result

multi_div(a, b) -> u1(a, b, 10)
u1(a, b, c) -> err | ¬(((((b ≠ 0) ∧ ¬(((a = -2147483648) ∧ (b = -1)))) ∧ ((c ≠ 0) ∧ ¬((((a / b) = -2147483648) ∧ (c = -1))))) ∧ ((-2147483648 ≤ (1 + ((a / b) / c))) ∧ ((1 + ((a / b) / c)) ≤ 2147483647))))
u1(a, b, c) -> u2(a, b, c, (1 + ((a / b) / c))) | ((((b ≠ 0) ∧ ¬(((a = -2147483648) ∧ (b = -1)))) ∧ ((c ≠ 0) ∧ ¬((((a / b) = -2147483648) ∧ (c = -1))))) ∧ ((-2147483648 ≤ (1 + ((a / b) / c))) ∧ ((1 + ((a / b) / c)) ≤ 2147483647)))
u2(a, b, c, x) -> ret(x)
