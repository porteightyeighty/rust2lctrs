div_cond :: Int -> Int -> result
ret :: Int -> result
err :: result
u1 :: Int -> Int -> result
u2 :: Int -> Int -> result

div_cond(a, b) -> err | ¬((b ≠ 0))
div_cond(a, b) -> u1(a, b) | ((b ≠ 0) ∧ ((a / b) > 0))
u1(a, b) -> ret(1)
div_cond(a, b) -> u2(a, b) | ((b ≠ 0) ∧ ¬(((a / b) > 0)))
u2(a, b) -> ret(0)
