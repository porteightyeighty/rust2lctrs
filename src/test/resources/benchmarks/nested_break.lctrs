nested_break :: Int -> result
ret :: Int -> result
err :: result
u1 :: Int -> Int -> result
u2 :: Int -> Int -> result
u3 :: Int -> Int -> result
u4 :: Int -> Int -> result
u5 :: Int -> Int -> Int -> result
u6 :: Int -> Int -> Int -> result
u7 :: Int -> Int -> Int -> result
u8 :: Int -> Int -> Int -> result
u9 :: Int -> Int -> Int -> result
u10 :: Int -> Int -> Int -> result
u11 :: Int -> Int -> Int -> result
u12 :: Int -> Int -> Int -> result
u13 :: Int -> Int -> result

nested_break(x) -> u1(x, 0)
u1(x, total) -> u2(x, total) | (x > 0)
u2(x, total) -> u3(x, total) | (total > 50)
u2(x, total) -> u4(x, total) | ¬((total > 50))
u4(x, total) -> u5(x, total, x)
u5(x, total, y) -> u6(x, total, y) | (y > 0)
u6(x, total, y) -> u7(x, total, y) | (y = 3)
u6(x, total, y) -> u8(x, total, y) | ¬((y = 3))
u8(x, total, y) -> err | ¬(((-32768 ≤ (total + 1)) ∧ ((total + 1) ≤ 32767)))
u8(x, total, y) -> u9(x, (total + 1), y) | ((-32768 ≤ (total + 1)) ∧ ((total + 1) ≤ 32767))
u9(x, total, y) -> err | ¬(((-32768 ≤ (y - 1)) ∧ ((y - 1) ≤ 32767)))
u9(x, total, y) -> u10(x, total, (y - 1)) | ((-32768 ≤ (y - 1)) ∧ ((y - 1) ≤ 32767))
u5(x, total, y) -> u11(x, total, y) | ¬((y > 0))
u10(x, total, y) -> u5(x, total, y)
u7(x, total, y) -> u11(x, total, y)
u11(x, total, y) -> err | ¬(((-32768 ≤ (x - 1)) ∧ ((x - 1) ≤ 32767)))
u11(x, total, y) -> u12((x - 1), total, y) | ((-32768 ≤ (x - 1)) ∧ ((x - 1) ≤ 32767))
u1(x, total) -> u13(x, total) | ¬((x > 0))
u12(x, total, y) -> u1(x, total)
u3(x, total) -> u13(x, total)
u13(x, total) -> ret(total)
