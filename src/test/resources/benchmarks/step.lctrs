step :: Int -> Int
u1 :: Int -> Int -> Int
u2 :: Int -> Int -> Int
u3 :: Int -> Int -> Int
u4 :: Int -> Int -> Int
u5 :: Int -> Int -> Int
u6 :: Int -> Int -> Int

step(x) -> u1(x, 0)
u1(x, y) -> u2(x, y) | (x > 0)
u2(x, y) -> u3(x, 1)
u1(x, y) -> u4(x, y) | ¬((x > 0))
u4(x, y) -> u5(x, (x - 1))
u3(x, y) -> u6(x, y)
u5(x, y) -> u6(x, y)
u6(x, y) -> y
