sum_skip_stuck :: Int -> Int
u1 :: Int -> Int -> Int
u2 :: Int -> Int -> Int -> Int
u3 :: Int -> Int -> Int -> Int
u4 :: Int -> Int -> Int -> Int
u5 :: Int -> Int -> Int -> Int
u6 :: Int -> Int -> Int -> Int
u7 :: Int -> Int -> Int -> Int
u8 :: Int -> Int -> Int -> Int

sum_skip_stuck(n) -> u1(n, 0)
u1(n, i) -> u2(n, i, 0)
u2(n, i, acc) -> u3(n, i, acc) | (i < n)
u3(n, i, acc) -> u4(n, i, acc) | (i = 5)
u4(n, i, acc) -> u2(n, i, acc)
u3(n, i, acc) -> u5(n, i, acc) | ¬((i = 5))
u5(n, i, acc) -> u6(n, (i + 1), acc)
u6(n, i, acc) -> u7(n, i, (acc + i))
u2(n, i, acc) -> u8(n, i, acc) | ¬((i < n))
u7(n, i, acc) -> u2(n, i, acc)
u8(n, i, acc) -> acc
