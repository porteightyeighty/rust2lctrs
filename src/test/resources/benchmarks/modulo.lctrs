modulo :: Int -> Int -> result
ret_Int :: Int -> result
err :: result
u1 :: Int -> Int -> Int -> result
u2 :: Int -> Int -> Int -> result

modulo(a, b) -> err | ¬((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1)))
modulo(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ ((a ≥ 0) ∨ ((a % b) = 0))) ∧ ($div = (a % b))
modulo(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b > 0))) ∧ ($div = ((a % b) - b))
modulo(a, b) -> u1(a, b, $div) | (((b ≠ 0) ∧ ¬((a = -32768) ∧ (b = -1))) ∧ (((a < 0) ∧ ((a % b) ≠ 0)) ∧ (b < 0))) ∧ ($div = ((a % b) + b))
u1(a, b, $div) -> u2(a, b, $div)
u2(a, b, x) -> ret_Int(x)
