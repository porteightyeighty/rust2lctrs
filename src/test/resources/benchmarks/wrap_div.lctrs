wrap_div :: Int -> Int -> result
ret_Int :: Int -> result
err :: result
u2 :: Int -> Int -> Int -> result

wrap_div(x, z) -> err | ¬((z ≠ 0) ∧ ¬((x = -32768) ∧ (z = -1)))
wrap_div(x, z) -> u2(x, z, $div) | (((z ≠ 0) ∧ ¬((x = -32768) ∧ (z = -1))) ∧ ((x ≥ 0) ∨ ((x % z) = 0))) ∧ ($div = (x / z))
wrap_div(x, z) -> u2(x, z, $div) | (((z ≠ 0) ∧ ¬((x = -32768) ∧ (z = -1))) ∧ (((x < 0) ∧ ((x % z) ≠ 0)) ∧ (z > 0))) ∧ ($div = ((x / z) + 1))
wrap_div(x, z) -> u2(x, z, $div) | (((z ≠ 0) ∧ ¬((x = -32768) ∧ (z = -1))) ∧ (((x < 0) ∧ ((x % z) ≠ 0)) ∧ (z < 0))) ∧ ($div = ((x / z) - 1))
u2(x, z, y) -> ret_Int(y)
